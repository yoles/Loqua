{
  "name": "@loqua/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "node scripts/copy-sqlite-wasm.mjs",
    "build": "next build",
    "build:export": "node scripts/copy-sqlite-wasm.mjs && DESKTOP_EXPORT=1 next build",
    "predev": "node scripts/copy-sqlite-wasm.mjs",
    "dev": "next dev",
