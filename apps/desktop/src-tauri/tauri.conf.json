{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Loqua",
  "version": "0.1.0",
  "identifier": "com.loqua.desktop",
  "build": {
    "beforeDevCommand": "node scripts/dev-frontend.mjs",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm --filter @loqua/web build:export",
    "frontendDist": "../../web/out"
  },
  "app": {
    "windows": [
      {
        "title": "Loqua",
        "width": 1100,
        "height": 800
      }
    ],
    "security": {
      "headers": {
        "Cross-Origin-Opener-Policy": "same-origin",
        "Cross-Origin-Embedder-Policy": "require-corp"
      },
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/loqua-llm-sidecar"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
